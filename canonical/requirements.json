from pathlib import Path
import json
import re

INPUT_FILE = Path("extracted/raw_extraction.json")
OUTPUT_FILE = Path("canonical/requirements.json")


def slug_to_title(text: str) -> str:
    text = text.strip().replace("_", " ")
    return text[:1].upper() + text[1:] if text else "Untitled"


def split_markdown_sections(markdown: str):
    """
    Split markdown into sections based on headings.
    If no headings exist, return one single section.
    """
    lines = markdown.splitlines()
    sections = []
    current_title = "General"
    current_content = []

    heading_pattern = re.compile(r"^(#+)\s+(.*)$")

    for line in lines:
        match = heading_pattern.match(line.strip())
        if match:
            if current_content:
                sections.append(
                    {
                        "title": current_title,
                        "text": "\n".join(current_content).strip()
                    }
                )
            current_title = match.group(2).strip()
            current_content = []
        else:
            current_content.append(line)

    if current_content:
        sections.append(
            {
                "title": current_title,
                "text": "\n".join(current_content).strip()
            }
        )

    return [s for s in sections if s["text"]]


def infer_requirement_type(source_type: str) -> str:
    if source_type == "business_source" or source_type == "business_template":
        return "business_requirement"
    if source_type == "functional_template":
        return "functional_requirement"
    if source_type == "non_functional_template":
        return "non_functional_requirement"
    if source_type == "matrix_template":
        return "matrix_requirement"
    return "business_requirement"


def main():
    if not INPUT_FILE.exists():
        raise FileNotFoundError(f"Missing input file: {INPUT_FILE}")

    with INPUT_FILE.open("r", encoding="utf-8") as f:
        extracted = json.load(f)

    documents = extracted.get("documents", [])
    requirements = []
    counter = 1

    for doc in documents:
        if doc.get("status") != "success":
            continue

        source_file = doc.get("file", "")
        source_type = doc.get("type", "")
        markdown = doc.get("markdown", "").strip()

        if not markdown:
            continue

        req_type = infer_requirement_type(source_type)
        sections = split_markdown_sections(markdown)

        for section in sections:
            requirement = {
                "requirement_id": f"BREQ-{counter:04d}",
                "type": req_type,
                "title": slug_to_title(section["title"]),
                "description": section["text"],
                "priority": "TBD",
                "source_file": source_file,
                "source_ref": section["title"],
                "status": "active",
                "acceptance_criteria": []
            }
            requirements.append(requirement)
            counter += 1

    output = {
        "requirements_count": len(requirements),
        "requirements": requirements
    }

    OUTPUT_FILE.parent.mkdir(parents=True, exist_ok=True)
    with OUTPUT_FILE.open("w", encoding="utf-8") as f:
        json.dump(output, f, indent=2, ensure_ascii=False)

    print(f"Created {OUTPUT_FILE}")


if __name__ == "__main__":
    main()
